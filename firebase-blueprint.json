{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with XP, levels, coins, and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID matching Firebase Auth" },
        "name": { "type": "string", "description": "Display name of the user" },
        "email": { "type": "string", "description": "User email address" },
        "age": { "type": "string", "description": "Age of the user" },
        "occupation": { "type": "string", "description": "User occupation" },
        "habitGoals": { "type": "string", "description": "User's overall objectives for breaking habits" },
        "reminderPreferences": { "type": "object", "description": "User preference settings for push or email reminders" },
        "xp": { "type": "integer", "description": "Experience points in the gamified system" },
        "level": { "type": "integer", "description": "User level based on XP" },
        "coins": { "type": "integer", "description": "Redeemable coins earned from breaking habits" },
        "badges": { "type": "array", "description": "Unlockable achievement badges" },
        "premium": { "type": "boolean", "description": "Whether the user is a premium member" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "xp", "level", "coins", "premium", "createdAt"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A bad habit that the user wants to identify, analyze, and overcome.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "severity": { "type": "string" },
        "recoveryDifficulty": { "type": "string" },
        "confidenceScore": { "type": "number" },
        "rootCauses": { "type": "array" },
        "triggerSituations": { "type": "array" },
        "emotionalPatterns": { "type": "array" },
        "longTermRisks": { "type": "array" },
        "streak": { "type": "integer" },
        "maxStreak": { "type": "integer" },
        "status": { "type": "string", "enum": ["active", "broken", "paused"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "category", "streak", "maxStreak", "status", "createdAt"]
    },
    "RecoveryPlan": {
      "title": "RecoveryPlan",
      "description": "A 21-day recovery plan generated by AI for a specific habit.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "habitId": { "type": "string" },
        "days": { "type": "array", "description": "Array of 21 objects representing daily goals, routines, and challenges" },
        "morningRoutine": { "type": "string" },
        "eveningRoutine": { "type": "string" },
        "healthyAlternatives": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "habitId", "days", "createdAt"]
    },
    "Challenge": {
      "title": "Challenge",
      "description": "A daily AI-generated challenge associated with the recovery plan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "xp": { "type": "integer" },
        "coins": { "type": "integer" },
        "status": { "type": "string", "enum": ["pending", "completed", "skipped"] },
        "date": { "type": "string", "format": "date" },
        "habitId": { "type": "string" }
      },
      "required": ["id", "userId", "title", "xp", "coins", "status", "date"]
    },
    "JournalEntry": {
      "title": "JournalEntry",
      "description": "Daily reflection logs with mood and AI summarization.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "mood": { "type": "string", "enum": ["Happy", "Calm", "Neutral", "Sad", "Stressed"] },
        "moodEmoji": { "type": "string" },
        "wins": { "type": "string" },
        "challenges": { "type": "string" },
        "lessons": { "type": "string" },
        "aiSummary": { "type": "string" },
        "aiPatterns": { "type": "array" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "content", "mood", "moodEmoji", "date", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Conversation message with the AI Motivation Coach.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "role", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "Stores core settings and gamified values for each user."
    },
    "/users/{userId}/habits/{habitId}": {
      "schema": { "$ref": "Habit" },
      "description": "Stores bad habits tracked by the user."
    },
    "/users/{userId}/recoveryPlans/{planId}": {
      "schema": { "$ref": "RecoveryPlan" },
      "description": "Stores generated recovery programs for the user's habits."
    },
    "/users/{userId}/challenges/{challengeId}": {
      "schema": { "$ref": "Challenge" },
      "description": "Stores daily gamified tasks for the user."
    },
    "/users/{userId}/journals/{journalId}": {
      "schema": { "$ref": "JournalEntry" },
      "description": "Stores user journal reflections and moods."
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": { "$ref": "ChatMessage" },
      "description": "Stores conversation history with the AI Motivation Coach."
    }
  }
}
