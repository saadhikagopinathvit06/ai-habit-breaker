rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 3. Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'xp', 'level', 'coins', 'premium', 'createdAt'])
          && data.uid is string && data.uid.size() <= 128
          && data.name is string && data.name.size() <= 128
          && data.email is string && data.email.size() <= 256
          && data.xp is int
          && data.level is int
          && data.coins is int
          && data.premium is bool;
    }

    function isValidHabit(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'category', 'streak', 'maxStreak', 'status', 'createdAt'])
          && data.id is string && data.id.size() <= 128
          && data.userId is string && data.userId.size() <= 128
          && data.name is string && data.name.size() <= 128
          && data.category is string && data.category.size() <= 128
          && data.streak is int
          && data.maxStreak is int
          && data.status is string && (data.status == 'active' || data.status == 'broken' || data.status == 'paused');
    }

    function isValidRecoveryPlan(data) {
      return data.keys().hasAll(['id', 'userId', 'habitId', 'days', 'createdAt'])
          && data.id is string && data.id.size() <= 128
          && data.userId is string && data.userId.size() <= 128
          && data.habitId is string && data.habitId.size() <= 128
          && data.days is list;
    }

    function isValidChallenge(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'xp', 'coins', 'status', 'date'])
          && data.id is string && data.id.size() <= 128
          && data.userId is string && data.userId.size() <= 128
          && data.title is string && data.title.size() <= 256
          && data.xp is int
          && data.coins is int
          && data.status is string && (data.status == 'pending' || data.status == 'completed' || data.status == 'skipped')
          && data.date is string;
    }

    function isValidJournal(data) {
      return data.keys().hasAll(['id', 'userId', 'content', 'mood', 'moodEmoji', 'date', 'createdAt'])
          && data.id is string && data.id.size() <= 128
          && data.userId is string && data.userId.size() <= 128
          && data.content is string && data.content.size() <= 10000
          && data.mood is string && (data.mood == 'Happy' || data.mood == 'Calm' || data.mood == 'Neutral' || data.mood == 'Sad' || data.mood == 'Stressed')
          && data.moodEmoji is string && data.moodEmoji.size() <= 8
          && data.date is string;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['id', 'userId', 'role', 'content', 'createdAt'])
          && data.id is string && data.id.size() <= 128
          && data.userId is string && data.userId.size() <= 128
          && data.role is string && (data.role == 'user' || data.role == 'assistant')
          && data.content is string && data.content.size() <= 5000;
    }

    // 4. Matches
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == existing().createdAt && (
        incoming().diff(existing()).affectedKeys().hasAny(['xp', 'level', 'coins', 'badges', 'name', 'age', 'occupation', 'habitGoals', 'reminderPreferences', 'premium'])
      );
      allow delete: if false;

      match /habits/{habitId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(habitId) && isValidHabit(incoming()) && incoming().userId == userId && incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidId(habitId) && isValidHabit(incoming()) && incoming().userId == userId && incoming().createdAt == existing().createdAt && (
          incoming().diff(existing()).affectedKeys().hasAny(['streak', 'maxStreak', 'status', 'name', 'description', 'category', 'severity', 'recoveryDifficulty', 'confidenceScore', 'rootCauses', 'triggerSituations', 'emotionalPatterns', 'longTermRisks'])
        );
        allow delete: if isOwner(userId);
      }

      match /recoveryPlans/{planId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(planId) && isValidRecoveryPlan(incoming()) && incoming().userId == userId && incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidId(planId) && isValidRecoveryPlan(incoming()) && incoming().userId == userId && incoming().createdAt == existing().createdAt && (
          incoming().diff(existing()).affectedKeys().hasAny(['days', 'morningRoutine', 'eveningRoutine', 'healthyAlternatives'])
        );
        allow delete: if isOwner(userId);
      }

      match /challenges/{challengeId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(challengeId) && isValidChallenge(incoming()) && incoming().userId == userId;
        allow update: if isOwner(userId) && isValidId(challengeId) && isValidChallenge(incoming()) && incoming().userId == userId && (
          incoming().diff(existing()).affectedKeys().hasAny(['status'])
        );
        allow delete: if isOwner(userId);
      }

      match /journals/{journalId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(journalId) && isValidJournal(incoming()) && incoming().userId == userId && incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidId(journalId) && isValidJournal(incoming()) && incoming().userId == userId && incoming().createdAt == existing().createdAt && (
          incoming().diff(existing()).affectedKeys().hasAny(['content', 'mood', 'moodEmoji', 'wins', 'challenges', 'lessons', 'aiSummary', 'aiPatterns'])
        );
        allow delete: if isOwner(userId);
      }

      match /chats/{chatId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(chatId) && isValidChatMessage(incoming()) && incoming().userId == userId && incoming().createdAt == request.time;
        allow update: if false;
        allow delete: if isOwner(userId);
      }
    }
  }
}
